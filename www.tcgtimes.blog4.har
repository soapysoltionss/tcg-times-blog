muted)] transition-colors -mx-2 px-2\",\"children\":[[\"$\",\"span\",null,{\"className\":\"label-upper text-[var(--text-muted)] pt-1 w-8 shrink-0\",\"children\":\"âš”ï¸\"}],[\"$\",\"div\",null,{\"className\":\"flex-1\",\"children\":[[\"$\",\"p\",null,{\"className\":\"text-xl font-bold text-[var(--foreground)] group-hover:opacity-60 transition-opacity leading-tight mb-1\",\"style\":{\"fontFamily\":\"var(--font-serif, 'Playfair Display', serif)\"},\"children\":\"Grand Archive\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-[var(--text-muted)] leading-relaxed\",\"children\":\"Theory crafting, deck analysis, and card evaluations for Grand Archive TCG â€” the anime-inspired collector's dream.\"}]]}],[\"$\",\"span\",null,{\"className\":\"label-upper text-[var(--text-muted)] pt-1 group-hover:text-[var(--foreground)] transition-colors\",\"children\":\"â†’\"}]]}],[\"$\",\"$L2\",\"flesh-and-blood\",{\"href\":\"/category/flesh-and-blood\",\"className\":\"group flex items-start gap-6 py-5 border-b border-[var(--border)] hover:bg-[var(--muted)] transition-colors -mx-2 px-2\",\"children\":[[\"$\",\"span\",null,{\"className\":\"label-upper text-[var(--text-muted)] pt-1 w-8 shrink-0\",\"children\":\"ðŸ©¸\"}],[\"$\",\"div\",null,{\"className\":\"flex-1\",\"children\":[[\"$\",\"p\",null,{\"className\":\"text-xl font-bold text-[var(--foreground)] group-hover:opacity-60 transition-opacity leading-tight mb-1\",\"style\":{\"fontFamily\":\"var(--font-serif, 'Playfair Display', serif)\"},\"children\":\"Flesh and Blood\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-[var(--text-muted)] leading-relaxed\",\"children\":\"Deep dives into hero matchups, equipment choices, and the evolving meta of Flesh and Blood.\"}]]}],[\"$\",\"span\",null,{\"className\":\"label-upper text-[var(--text-muted)] pt-1 group-hover:text-[var(--foreground)] transition-colors\",\"children\":\"â†’\"}]]}],[\"$\",\"$L2\",\"one-piece-tcg\",{\"href\":\"/category/one-piece-tcg\",\"className\":\"group flex items-star