# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo

# local docs (never push)
DOCS.md
MARKDOWN.md
next-env.d.ts
*.har

# learning-quant — private tool, never push source or node_modules
/learning-quant/src/
/learning-quant/node_modules/
/learning-quant/dist/
/learning-quant/public/
/learning-quant/*.json
/learning-quant/*.ts
/learning-quant/*.html
/learning-quant/*.js
/learning-quant/scripts/
